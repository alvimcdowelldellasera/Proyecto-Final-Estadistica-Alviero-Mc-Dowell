            ax.set_title('DISTRIBUCIÓN DE FRECUENCIAS (CONCENTRACIÓN)', fontweight='bold')
        elif tipo == 'box':
            ax.boxplot(val, vert=False, patch_artist=True, boxprops=dict(facecolor='#8ea9db'))
            ax.set_title('ANÁLISIS DE DISPERSIÓN Y OUTLIERS', fontweight='bold')
        elif tipo == 'bar':
            ax.bar(['Pob. Total (Conteo)', 'Segmento Ult. Año'], [len(df), n_B], color=['#d9d9d9', '#2e75b6'])
            ax.set_title('SEGMENTACIÓN DE MUESTRAS (DIAGRAMA DE VENN)', fontweight='bold')
        elif tipo == 'line':
            df.groupby('TIME_PERIOD')['OBS_VALUE'].mean().plot(color='#c00000', linewidth=2, marker='o')
            ax.set_title('EVOLUCIÓN DEL VALOR COMERCIAL POR PERIODO', fontweight='bold')
        
        plt.tight_layout()
        # Explicitar formato y remover canal alfa para evitar fallos en FPDF
        fig.savefig(nombre, dpi=150, format='png', facecolor='white', edgecolor='none')
        plt.close(fig)

