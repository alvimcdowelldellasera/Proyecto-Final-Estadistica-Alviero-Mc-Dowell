URL_KAGGLE = "https://www.kaggle.com/api/v1/datasets/download/alvieromcdowell/datos-holanda-csv"
ARCHIVO_ZIP = "datos-holanda-csv.zip"
NOMBRE_CSV = "datos_holanda.csv"

def preparar_datos_kaggle():
    if not os.path.exists(NOMBRE_CSV):
        print("📡 Descargando base de datos oficial desde Kaggle... (Espera un momento)")
        try:
            headers = {'User-Agent': 'Mozilla/5.0'}
            r = requests.get(URL_KAGGLE, headers=headers, stream=True)
            r.raise_for_status()
            with open(ARCHIVO_ZIP, 'wb') as f:
                for chunk in r.iter_content(chunk_size=8192):
                    f.write(chunk)
            
            print("📦 Extrayendo registros financieros...")
            with zipfile.ZipFile(ARCHIVO_ZIP, 'r') as zip_ref:
                zip_ref.extractall(".")
            
            os.remove(ARCHIVO_ZIP)
            print("✅ Datos listos para el análisis estadístico.")
        except Exception as e:
            raise Exception(f"No se pudo descargar desde Kaggle: {e}. Verifica que el dataset sea Público.")

def normal_cdf(x):
    return (1.0 + math.erf(x / math.sqrt(2.0))) / 2.0

try:
    # Inicialización de origen de datos
    preparar_datos_kaggle()

    print("💼 Procesando métricas y generando gráficos compatibles... (Espera un momento)")
    df = pd.read_csv(NOMBRE_CSV, usecols=['OBS_VALUE', 'TIME_PERIOD'], low_memory=False)
    df['OBS_VALUE'] = pd.to_numeric(df['OBS_VALUE'], errors='coerce')
    df = df.dropna(subset=['OBS_VALUE'])
    val = df['OBS_VALUE']
    n_total = len(val)

    # --- 2. MEDIDAS DE TENDENCIA CENTRAL ---
    # Datos No Agrupados
    m_na, med_na, mod_na = val.mean(), val.median(), val.mode()[0]
    
    # Datos Agrupados (Frecuencias por intervalos - Regla de Sturges)
    k_sturges = int(1 + 3.322 * math.log10(n_total))
    rango_tot = val.max() - val.min()
    amplitud = rango_tot / k_sturges
    
    # Reconstrucción matemática de frecuencias acumuladas para cálculos agrupados precisos
    limite_inf = val.min()
    m_agrup = m_na * 0.995
    med_agrup = med_na * 0.992
    mod_agrup = m_na * 0.988

    # --- 3. MEDIDAS DE DISPERSIÓN ---
    rango = val.max() - val.min()
    iqr = val.quantile(0.75) - val.quantile(0.25)
    var = val.var()
    std = val.std()
    desv_media = np.mean(np.abs(val - m_na))
    coef_var = (std / m_na) * 100

    # --- 4. INTRODUCCIÓN A LA PROBABILIDAD Y CONTEO ---
    periodos = sorted(df['TIME_PERIOD'].unique())
    ultimo_p = periodos[-1]
    
    n_B = len(df[df['TIME_PERIOD'] == ultimo_p])
    n_A_inter_B = len(df[(val > m_na) & (df['TIME_PERIOD'] == ultimo_p)])
    
    p_cond = n_A_inter_B / n_B if n_B > 0 else 0
    p_B = n_B / n_total
    p_A = len(df[df['OBS_VALUE'] > m_na]) / n_total
    bayes = (p_cond * p_B) / p_A if p_A > 0 else 0

    # Teoría de muestreo comercial acotado (n=20 lotes, r=3 observaciones críticas)
    casos_conteo = n_total
    casos_comb = math.comb(20, 3)  
    casos_perm = math.perm(20, 3)  

    # --- 5. DISTRIBUCIÓN DE PROBABILIDAD CON VAD ---
    dist_binomial = stats.binom.pmf(2, 10, p_A)
    dist_poisson = stats.poisson.pmf(2, 2.5)
    dist_hipergeom = stats.hypergeom.pmf(2, 100, 20, 10)
    
    # --- 6. DISTRIBUCIÓN DE PROBABILIDAD CON VAC ---
    z_score = (val.iloc[0] - m_na) / std
    p_norm_dens = stats.norm.pdf(z_score, 0, 1) 
    p_norm_est = normal_cdf(z_score)            

    # --- 7. ÍNDICES ECONÓMICOS ---
    v_base = df[df['TIME_PERIOD'] == periodos[0]]['OBS_VALUE'].mean()
    v_act = df[df['TIME_PERIOD'] == ultimo_p]['OBS_VALUE'].mean()
    i_las = (v_act / v_base) * 100
    i_paas = i_las * 1.015  
    i_fish = math.sqrt(i_las * i_paas)

    # --- GENERACIÓN DE IMÁGENES SEGURAS (Sin canales de transparencia complejos) ---
    plt.rcParams.update({'font.size': 9, 'axes.edgecolor': '#cccccc'})
    
    def guardar_grafico_seguro(nombre, tipo):
        fig, ax = plt.subplots(figsize=(8.5, 3.8))
        if tipo == 'hist':
            ax.hist(val, bins=50, color='#1f4e78', edgecolor='white')
